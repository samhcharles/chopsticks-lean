{
  "name": "chopsticks-lean",
  "version": "2.1.0",
  "type": "module",
  "description": "A lean PostgreSQL/Redis-backed Discord bot focused on moderation, core server tooling, and VoiceMaster custom VC workflows.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/samhcharles/chopsticks-lean.git"
  },
  "homepage": "https://github.com/samhcharles/chopsticks-lean",
  "bugs": {
    "url": "https://github.com/samhcharles/chopsticks-lean/issues"
  },
  "keywords": [
    "discord",
    "discord-bot",
    "moderation",
    "voicemaster",
    "custom-vc",
    "postgres",
    "redis",
    "self-hosted"
  ],
  "scripts": {
    "bot": "STORAGE_DRIVER=postgres node src/index.js",
    "bot:inspect": "STORAGE_DRIVER=postgres node --inspect=0.0.0.0:9229 src/index.js",
    "bot:inspect:local": "STORAGE_DRIVER=postgres node --inspect=127.0.0.1:9229 src/index.js",
    "start": "npm run bot",
    "migrate": "node scripts/migrate.js",
    "verify": "node scripts/verify-setup.js",
    "deploy:guild": "DEPLOY_MODE=guild node scripts/deployCommands.js",
    "deploy:global": "DEPLOY_MODE=global node scripts/deployCommands.js",
    "clear:guild": "CLEAR_MODE=guild node scripts/clearCommands.js",
    "clear:global": "CLEAR_MODE=global node scripts/clearCommands.js",
    "ci:syntax": "find src scripts test migrations -name '*.js' -print0 | xargs -0 -n1 node --check",
    "ci:migrations": "node scripts/ci/check-migrations.mjs",
    "ci:boot": "CI_SKIP_DISCORD_LOGIN=true HEALTH_PORT=-1 METRICS_PORT=-1 STORAGE_DRIVER=postgres DASHBOARD_ENABLED=false AGENTS_ENABLED=false MUSIC_ENABLED=false node src/index.js",
    "ops:watchdog": "bash scripts/ops/chopsticks-watchdog.sh",
    "ops:auto-update": "bash scripts/ops/chopsticks-auto-update.sh",
    "ops:install-systemd": "bash scripts/ops/install-systemd.sh",
    "ops:uninstall-systemd": "bash scripts/ops/uninstall-systemd.sh",
    "ops:install-update-timer": "bash scripts/ops/install-update-timer.sh",
    "ops:uninstall-update-timer": "bash scripts/ops/uninstall-update-timer.sh",
    "test": "mocha 'test/unit/**/*.test.js'",
    "test:watch": "mocha 'test/unit/**/*.test.js' --watch"
  },
  "dependencies": {
    "@discordjs/voice": "^0.19.2",
    "@napi-rs/canvas": "^0.1.99",
    "@snazzah/davey": "^0.1.11",
    "async": "^3.2.6",
    "async-retry": "^1.3.3",
    "discord.js": "^14.26.3",
    "dotenv": "^16.4.5",
    "epub2": "^3.0.2",
    "express": "^5.2.1",
    "fuse.js": "^7.3.0",
    "ioredis": "^5.10.1",
    "joi": "^18.1.2",
    "mammoth": "^1.12.0",
    "msedge-tts": "^2.0.5",
    "opossum": "^8.1.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3",
    "rate-limiter-flexible": "^9.1.1",
    "redis": "^5.12.1",
    "sodium-native": "^5.1.0",
    "undici": "^6.23.0"
  },
  "devDependencies": {
    "mocha": "^11.7.5"
  },
  "overrides": {
    "undici": "^6.23.0",
    "minimatch": "^10.2.1",
    "glob": "^11.0.0",
    "rimraf": "^6.0.0",
    "form-data": "^4.0.0",
    "tough-cookie": "^4.1.3",
    "tar": ">=7.5.8"
  }
}
